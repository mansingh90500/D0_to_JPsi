OOJPsiSkim::OOJPsiSkim(const edm::ParameterSet& theParameters) :
    theConfig(theParameters)
   {
        using std::string;
        token_tracks = consumes<edm::View<pat::PackedCandidate>>(theParameters.getParameter<edm::InputTag>("TrackLabel"));
        token_vertices = consumes<reco::VertexCollection>(theParameters.getParameter<edm::InputTag>("VertexLabel"));

        recoJPsiCompositeCandidate_Token_ = consumes<pat::CompositeCandidateCollection>(theConfig.getUntrackedParameter<edm::InputTag>("JPsiCollection"));
        
        // ADD: Token for muons to access soft muon ID
        muonCollectionToken_ = consumes<pat::MuonCollection>(theConfig.getUntrackedParameter<edm::InputTag>("MuonCollection", edm::InputTag("unpackedMuons")));
    }

OOJPsiSkim::~OOJPsiSkim() {

    delete pVectVectVect_trg;
    delete pVectVect_ass;
    delete zvtxVect;
    delete nNtrkoffline;
    delete ncent;
    delete ncentBin;

}

int OOJPsiSkim::getCentralityGroup(int cent) const {
    for (int i = 0; i < nCentBins; ++i) {
        if (cent >= centBinMin[i] && cent <= centBinMax[i]) return i;
    }
    return -1;
}

void OOJPsiSkim::analyze(const edm::Event &iEvent, const edm::EventSetup &iSetup)
{
    using std::vector;
    using std::cout;
    using std::endl;
    using namespace reco;
    using namespace edm;

    // Get the vertex
    Handle<reco::VertexCollection> theVertexHandle;
    iEvent.getByToken(token_vertices, theVertexHandle);
    if(theVertexHandle->size() == 0) return;
    

    // select on requirement of valid vertex
    bestvz=-999.9; 
    bestvx=-999.9; 
    bestvy=-999.9;
    double bestvzError=-999.9, bestvxError=-999.9, bestvyError=-999.9;

    const reco::VertexCollection vtxCollection = *(theVertexHandle.product());
    reco::VertexCollection::const_iterator vtxPrimary = vtxCollection.begin();

    if(vtxPrimary->isFake()) return;

    bestvx = vtxPrimary->x();
    bestvy = vtxPrimary->y();
    bestvz = vtxPrimary->z();
    bestvzError = vtxPrimary->zError(); 
    bestvxError = vtxPrimary->xError(); 
    bestvyError = vtxPrimary->yError();

    if (bestvz > 15.0 || bestvz < -15.0) return;

    math::XYZPoint bestvtx(bestvx, bestvy, bestvz);

    // Get the tracks
    auto theTrackHandle = iEvent.getHandle(token_tracks);
    if (!theTrackHandle->size()) return;

    // do the track collection
    auto input_cands = *theTrackHandle;
    edm::View<pat::PackedCandidate>::const_iterator indx;

    
    nMult_Ntrkoffline = 0;
    float toppt=-999;

    for (indx = input_cands.begin(); indx != input_cands.end(); indx++)
    {
        // select tracks
        if (!indx->hasTrackDetails())continue;
        if (abs(indx->charge()) != 1)continue;
        if (!(indx->pseudoTrack().quality(reco::TrackBase::qualityByName("highPurity"))))continue;

        const Track &tmpTrack = indx->pseudoTrack();

        // DCA cut
        float dzvtx = tmpTrack.dz(bestvtx);
        float dxyvtx = tmpTrack.dxy(bestvtx);
        float dzerror = sqrt(tmpTrack.dzError() * tmpTrack.dzError() + bestvzError * bestvzError);
        float dxyerror = sqrt(tmpTrack.d0Error() * tmpTrack.d0Error() + bestvxError * bestvyError);

        if (fabs(tmpTrack.ptError()) / tmpTrack.pt() > 0.10)continue;
        if (fabs(dzvtx / dzerror) > 3)continue;
        if (fabs(dxyvtx / dxyerror) > 3)continue;
        if (fabs(dzvtx) > 9999.0) continue;

        if (tmpTrack.eta() > -2.4 && tmpTrack.eta() < 2.4 && tmpTrack.pt() > 0.4)
            nMult_Ntrkoffline++;
        if (tmpTrack.eta() < 2.4 && tmpTrack.eta() > -2.4 &&  tmpTrack.pt() > toppt)
            toppt = tmpTrack.pt();

    }
    
    if(nMult_Ntrkoffline < 0 || nMult_Ntrkoffline > 2000) return;
    if(toppt < 0 || toppt > 9999.0) return;
    hNtrk->Fill(nMult_Ntrkoffline);

    float etHFtowerSumPlus = 0;
    float etHFtowerSumMinus = 0;
    float etHFtowerSum = 0;

    //use sum of et to sperate centrality bins
    for(indx=input_cands.begin(); indx != input_cands.end(); indx++) {

            if(indx->pdgId() == 1 || indx->pdgId() == 2)  {
                //HF+
                if(indx->eta() > 3.0 && indx->eta() < 5.2) etHFtowerSumPlus += indx->et();
                //HF-
                if(indx->eta() > -5.2 && indx->eta() < -3.0) etHFtowerSumMinus += indx->et();
            }
    } 

    etHFtowerSum = etHFtowerSumPlus + etHFtowerSumMinus;

    int cent = -1;
    for (int ic=0; ic < nCentTableBins; ic++){
        if(etHFtowerSum>binBoundaries[ic] && etHFtowerSum<binBoundaries[ic+1]){
        cent = nCentTableBins -1 - ic;
        }
    }

    int centGroup = getCentralityGroup(cent);
    if(centGroup < 0) return;

    //get associated particles
    pVect_ass = new vector<Particle_ass>;

    for (indx = input_cands.begin(); indx != input_cands.end(); indx++){
            if (!indx->hasTrackDetails())continue;
            if (abs(indx->charge()) != 1)continue;
            if (!(indx->pseudoTrack().quality(reco::TrackBase::qualityByName("highPurity"))))continue;

            const Track &tmpTrack = indx->pseudoTrack();

            float dzvtx = tmpTrack.dz(bestvtx);
            float dxyvtx = tmpTrack.dxy(bestvtx);
            float dzerror = sqrt(tmpTrack.dzError() * tmpTrack.dzError() + bestvzError * bestvzError);
            float dxyerror = sqrt(tmpTrack.d0Error() * tmpTrack.d0Error() + bestvxError * bestvyError);

            if (fabs(tmpTrack.ptError()) / tmpTrack.pt() > 0.10)continue;
            if (fabs(dzvtx / dzerror) > 3)continue;
            if (fabs(dxyvtx / dxyerror) > 3)continue;
            if (fabs(dzvtx) > 9999.0) continue;

            float eta = tmpTrack.eta();
            float phi = tmpTrack.phi();
            float pt  = tmpTrack.pt();

            Particle_ass part;
            part.pt = pt;
            part.eta = eta;
            part.phi = phi;

            if(eta<=2.4 && eta>=-2.4 && pt<=3.0 && pt>=0.3) pVect_ass->push_back(part);
    }

    int nAssoc = pVect_ass->size();
    hNassoc_global->Fill((double)nAssoc);
    sumNassoc += nAssoc;
    countNassocEvents++;
    
    std::vector<std::vector<std::vector<Particle_trg>>> particlesPerBin(nPtBins, std::vector<std::vector<Particle_trg>>(nMassBins));

    edm::Handle<pat::CompositeCandidateCollection> JPsiCandidates;
    iEvent.getByToken(recoJPsiCompositeCandidate_Token_, JPsiCandidates);
    if(!JPsiCandidates.isValid()) return;
    const pat::CompositeCandidateCollection * JPsiCandidates_ = JPsiCandidates.product();

    // Get muon collection for soft muon ID
    edm::Handle<pat::MuonCollection> muons;
    iEvent.getByToken(muonCollectionToken_, muons);

    for(unsigned it=0; it<JPsiCandidates_->size(); ++it){
        
        const pat::CompositeCandidate & jpsi = (*JPsiCandidates_)[it];

        float eta = jpsi.eta();
        float pt = jpsi.pt();
        float phi = jpsi.phi();
        y = jpsi.rapidity();
        
        if(std::abs(y) < 1.6 || std::abs(y) > 2.4) continue;  // Enforce 1.6 < |y| < 2.4
        
        double px = jpsi.px();
        double py = jpsi.py();
        double pz = jpsi.pz();
        mass = jpsi.mass();
        
        if(jpsi.numberOfDaughters() != 2) continue;
        
        const reco::Candidate * d1 = jpsi.daughter(0);
        const reco::Candidate * d2 = jpsi.daughter(1);
        
        const pat::Muon* mu0 = dynamic_cast<const pat::Muon*>(d1);
        const pat::Muon* mu1 = dynamic_cast<const pat::Muon*>(d2);
        
        if(!mu0 || !mu1) continue;
        
        // Check opposite charges
        if(mu0->charge() * mu1->charge() >= 0) continue;
        
        // Soft muon ID cuts (your provided selections)
        if(!mu0->isPFMuon() || !mu1->isPFMuon()) continue;
        if(!mu0->isSoftMuon(*vtxPrimary) || !mu1->isSoftMuon(*vtxPrimary)) continue;
        
        // Vertex probability cut
        double vtxProb = jpsi.userFloat("vProb");
        if(vtxProb < 0.01) continue;
        
        // Muon acceptance cuts
        if(mu0->p() <= 3.0 || mu1->p() <= 3.0) continue;  // Total momentum > 3 GeV
        if(std::abs(mu0->eta()) >= 2.4 || std::abs(mu1->eta()) >= 2.4) continue;  // Eta acceptance
        
        auto trk0 = mu0->bestTrack();
        auto trk1 = mu1->bestTrack();
        if(!trk0 || !trk1) continue;

        // Extract muon track properties
        pt1 = mu0->pt();
        pt2 = mu1->pt();
        
        p1 = mu0->p();
        p2 = mu1->p();
        
        eta1 = mu0->eta();
        eta2 = mu1->eta();

        phi1 = mu0->phi();
        phi2 = mu1->phi();
        
        charge1 = mu0->charge();
        charge2 = mu1->charge();

        // Track quality variables
        trkChi1 = trk0->normalizedChi2();
        trkChi2 = trk1->normalizedChi2();
        
        ptErr1 = trk0->ptError();
        ptErr2 = trk1->ptError();
        
        nhit1 = trk0->numberOfValidHits();
        nhit2 = trk1->numberOfValidHits();

        // DCA calculations for muon tracks
        double dzbest1 = trk0->dz(bestvtx);
        double dxybest1 = trk0->dxy(bestvtx);
        double dzerror1 = sqrt(trk0->dzError()*trk0->dzError()+bestvzError*bestvzError);
        double dxyerror1 = sqrt(trk0->d0Error()*trk0->d0Error()+bestvxError*bestvyError);

        dzos1 = dzbest1/dzerror1;
        dxyos1 = dxybest1/dxyerror1;
        
        double dzbest2 = trk1->dz(bestvtx);
        double dxybest2 = trk1->dxy(bestvtx);
        double dzerror2 = sqrt(trk1->dzError()*trk1->dzError()+bestvzError*bestvzError);
        double dxyerror2 = sqrt(trk1->d0Error()*trk1->d0Error()+bestvxError*bestvyError);
        
        dzos2 = dzbest2/dzerror2;
        dxyos2 = dxybest2/dxyerror2;

        // Vertex quality for J/psi
        //vtxChi2 = jpsi.vertexChi2();
        //ndf = jpsi.vertexNdof();
        //VtxProb = TMath::Prob(vtxChi2, ndf);

        // ========== J/PSI SPECIFIC QUALITY CUTS ==========
                if(mass < 2.6 || mass > 3.5) continue;
                if(pt < 0.0 || pt > 14.0) continue;
        
        // Muon track quality cuts (softer than hadron requirements)
        //if(nhit1 < 5 || nhit2 < 5) continue;  // Muon tracks have fewer hits than hadrons
        //if(std::abs(dzos1) > 3 || std::abs(dzos2) > 3) continue;  // DCA/z cut
        //if(std::abs(dxyos1) > 3 || std::abs(dxyos2) > 3) continue;  // DCA/xy cut
        
        // pT error cuts for muons (softer than hadrons)
        //if(ptErr1/pt1 >= 0.2 || ptErr2/pt2 >= 0.2) continue;
        

        // ========== FILL HISTOGRAMS ==========
        
        // Reconstructed J/psi properties
        hpt->Fill(pt);
        heta->Fill(eta);
        hphi->Fill(phi);
        hrapidity->Fill(y);
        hmass->Fill(mass);
        
        hptrap->Fill(y, pt);
        hpteta->Fill(eta, pt);
        hptetaMu->Fill(eta1, pt1);
        hptetaMu->Fill(eta2, pt2);
        
        // Fill mass spectrum for each pT bin
        for (int iPtBin = 0; iPtBin < nPtBins; iPtBin++)
        {
            if (pt >= ptCuts[iPtBin] && pt < ptCuts[iPtBin+1]) {
                CentPtBins_all[centGroup][iPtBin].hmass->Fill(mass);
                CentPtBins_all[centGroup][iPtBin].heta_ptBin->Fill(eta);
                CentPtBins_all[centGroup][iPtBin].hphi_ptBin->Fill(phi);
                break;
            }
        }

        // ========== PREPARE TRIGGER PARTICLE FOR 2-PARTICLE CORRELATION ==========
        
        Particle_trg part;
        part.pt = pt;
        part.eta = eta;
        part.phi = phi;
        part.eta_mu1 = mu0->eta();      // Changed from eta_dau1
        part.phi_mu1 = mu0->phi();      // Changed from phi_dau1
        part.eta_mu2 = mu1->eta();      // Changed from eta_dau2
        part.phi_mu2 = mu1->phi();      // Changed from phi_dau2
        part.charge_mu1 = mu0->charge();
        part.charge_mu2 = mu1->charge();
        part.isTrigger = true;

        // Bin J/psi by (pT, mass) for flow measurement
        for (int iPtBin = 0; iPtBin < nPtBins; iPtBin++)
        {
            if (pt >= ptCuts[iPtBin] && pt < ptCuts[iPtBin+1]) {
                // For J/psi flow analysis, use mass bins as signal/sideband regions
                for (int iMassBin = 0; iMassBin < nMassBins; iMassBin++){
                    if (mass >= massCuts[iMassBin] && mass < massCuts[iMassBin+1]){
                        particlesPerBin[iPtBin][iMassBin].push_back(part);
                        break;
                    }
                }
                break;
            }
        }
        
    } // End J/psi candidate loop


    for (int iPtBin = 0; iPtBin < nPtBins; iPtBin++) {
        for (int iMassBin = 0; iMassBin < nMassBins; iMassBin++) {
            const auto& binParticles = particlesPerBin[iPtBin][iMassBin];
            int nTotal = binParticles.size();  

            Histograms& ptBin = CentPtBins_all[centGroup][iPtBin];
            MassBinHistograms& h = ptBin.PtMassBins_SB[iMassBin];
            
            if (nTotal > 0) {     
                
                h.hMult_bins->Fill(nTotal);
            
                for (const auto& part_trg : binParticles) {

                    float eta_trg = part_trg.eta;
                    float phi_trg = part_trg.phi;
                    
                    for (const auto& part_ass : *pVect_ass) {  
                        float pt_ass = part_ass.pt;
                        float eta_ass = part_ass.eta;
                        float phi_ass = part_ass.phi;

                        float eff_ass = effhisto->GetBinContent(effhisto->FindBin(eta_ass,pt_ass,cent));
                        float fake_ass = fakehisto->GetBinContent(fakehisto->FindBin(eta_ass,pt_ass,cent));
                        float sec_ass = sechisto->GetBinContent(sechisto->FindBin(eta_ass,pt_ass,cent));
                        float mul_ass = mulhisto->GetBinContent(mulhisto->FindBin(eta_ass,pt_ass,cent));

                        float effweight_ass = eff_ass * (1 + mul_ass) / (1 - fake_ass) / (1 - sec_ass);
                    
                        
                        float deltaEta=eta_ass-eta_trg;
                        float deltaPhi=phi_ass-phi_trg;

                        float deltaEta_mu1 = part_trg.eta_mu1 - eta_ass;  // Changed from eta_dau1
                        float deltaPhi_mu1 = part_trg.phi_mu1 - phi_ass;  // Changed from phi_dau1
                        float deltaEta_mu2 = part_trg.eta_mu2 - eta_ass;  // Changed from eta_dau2
                        float deltaPhi_mu2 = part_trg.phi_mu2 - phi_ass;  // Changed from phi_dau2

                        if(deltaPhi>PI) deltaPhi=deltaPhi-2*PI;
                        if(deltaPhi<-PI) deltaPhi=deltaPhi+2*PI;
                        if(deltaPhi>-PI && deltaPhi<-PI/2.) deltaPhi=deltaPhi+2*PI;

                        if(deltaPhi_mu1 > PI) deltaPhi_mu1 -= 2*PI;
                        if(deltaPhi_mu1 < -PI) deltaPhi_mu1 += 2*PI;
                        if(deltaPhi_mu1 > -PI && deltaPhi_mu1 < -PI/2.) deltaPhi_mu1 += 2*PI;

                        if(deltaPhi_mu2 > PI) deltaPhi_mu2 -= 2*PI;
                        if(deltaPhi_mu2 < -PI) deltaPhi_mu2 += 2*PI;
                        if(deltaPhi_mu2 > -PI && deltaPhi_mu2 < -PI/2.) deltaPhi_mu2 += 2*PI;
                        
                        //if(deltaEta==0 && deltaPhi==0) continue;
                        if(fabs(deltaEta)==0 && fabs(deltaPhi)==0) continue;
                        if((fabs(deltaEta_mu1)<tolerance && fabs(deltaPhi_mu1)<tolerance) ||
                           (fabs(deltaEta_mu2)<tolerance && fabs(deltaPhi_mu2)<tolerance)) continue;
                        h.hSignal->Fill(deltaEta,deltaPhi,1.0/nTotal/effweight_ass);
                    }
                }
            }
        }
        
    }

    // =========================
    // ch-ch same-event reference
    // =========================
    const auto& ch = *pVect_ass;
    const int nCh = (int)ch.size();

    if (nCh > 1) {
        hMult_ch_cent[centGroup]->Fill(nCh);

        for (int i = 0; i < nCh; ++i) {
            const auto& trg = ch[i];

            // same correction style as your existing assoc weight
            float eff_trg  = effhisto->GetBinContent(effhisto->FindBin(trg.eta, trg.pt, cent));
            float fake_trg = fakehisto->GetBinContent(fakehisto->FindBin(trg.eta, trg.pt, cent));
            float sec_trg  = sechisto->GetBinContent(sechisto->FindBin(trg.eta, trg.pt, cent));
            float mul_trg  = mulhisto->GetBinContent(mulhisto->FindBin(trg.eta, trg.pt, cent));

            float effweight_trg = eff_trg * (1 + mul_trg) / (1 - fake_trg) / (1 - sec_trg);
            if (effweight_trg <= 0) continue;

            for (int j = 0; j < nCh; ++j) {
                if (i == j) continue; // remove self-pair

                const auto& ass = ch[j];

                float deltaEta = ass.eta - trg.eta;
                float deltaPhi = ass.phi - trg.phi;

                if (deltaPhi > PI)  deltaPhi -= 2 * PI;
                if (deltaPhi < -PI) deltaPhi += 2 * PI;
                if (deltaPhi > -PI && deltaPhi < -PI/2.) deltaPhi += 2 * PI;

                if (fabs(deltaEta) < tolerance && fabs(deltaPhi) < tolerance) continue;

                hSignal_chch_cent[centGroup]->Fill(deltaEta, deltaPhi, 1.0 / nCh / effweight_trg);
            }
        }
    }
    
    pVectVectVect_trg->push_back(particlesPerBin);
    pVectVect_ass->push_back(*pVect_ass);
    zvtxVect->push_back(bestvz);
    nNtrkoffline->push_back(nMult_Ntrkoffline);
    ncent->push_back(cent);
    ncentBin->push_back(centGroup);

    delete pVect_ass;

}
// ------------ method called once each job just before starting event loop  ------------
void OOJPsiSkim::beginJob() {
    edm::Service<TFileService> fs;

    TH1D::SetDefaultSumw2();
    TH2D::SetDefaultSumw2();

    //edm::FileInPath fip1("mytry/DemoAnalyzer/data/Eff_OO_2025_Hijing_MB_Centrality_NoPU_3D_Nominal_Official.root");
    edm::FileInPath fip1("Analyzer_v2/Analyzer/data/Eff_OO_2025_Hijing_MB_Centrality_NoPU_3D_Nominal_Official.root");
    TFile f1(fip1.fullPath().c_str(), "READ");
    effhisto = (TH3F*)f1.Get("hEff_3D");
    effhisto->SetDirectory(nullptr); 
    fakehisto = (TH3F*)f1.Get("hFak_3D");
    fakehisto->SetDirectory(nullptr); 
    sechisto = (TH3F*)f1.Get("hSec_3D");
    sechisto->SetDirectory(nullptr); 
    mulhisto = (TH3F*)f1.Get("hMul_3D");
    mulhisto->SetDirectory(nullptr); 
    f1.Close();  

    hNtrk = fs->make<TH1D>("hNtrk", "Number of good tracks; N_{trk}; Events", 500, 0, 500);

    //hpt = fs->make<TH1D>("hpt", "D^{0} transverse momentum; p_{T} (GeV/c); Entries", 200, 0, 20);
    //heta = fs->make<TH1D>("heta", "D^{0} pseudorapidity; #eta; Entries", 100, -3, 3);
    //hrapidity = fs->make<TH1D>("hrapidity", "D^{0} rapidity; y; Entries", 100, -2, 2);
    //hphi = fs->make<TH1D>("hphi", "D^{0} azimuthal angle; #phi; Entries", 90, -PI, PI);
    //hmass = fs->make<TH1D>("hmass", "D^{0} invariant mass; m_{K#pi} (GeV/c^{2}); Entries", 60, 1.7, 2.0);
    hpt = fs->make<TH1D>("hpt", "J/#psi transverse momentum; p_{T} (GeV/c); Entries", 200, 0, 10);
    heta = fs->make<TH1D>("heta", "J/#psi pseudorapidity; #eta; Entries", 120, -6, 6);
    hrapidity = fs->make<TH1D>("hrapidity", "J/#psi rapidity; y; Entries", 100, -2.5, 2.5);  // J/psi rapidity range
    hphi = fs->make<TH1D>("hphi", "J/#psi azimuthal angle; #phi; Entries", 90, -PI, PI);
    hmass = fs->make<TH1D>("hmass", "J/#psi invariant mass; m_{#mu#mu} (GeV/c^{2}); Entries", 90, 2.6, 3.5);  // J/psi mass window

    hptrap = fs->make<TH2D>("hpT_rap", "", 60 , -2.5, 2.5,50 , 0.0, 10.0);
    hpteta = fs->make<TH2D>("hpT_eta", "", 60 , -6.0, 6.0,50 , 0.0, 10.0);
    hptetaMu = fs->make<TH2D>("hpT_etaMu", "", 60 , -2.5, 2.5,50 , 0.0, 10.0);
    //
    hNassoc_global = fs->make<TH1D>(
        "hNassoc_global",
        "Number of associated particles per event;N_{assoc};Events",
        400, 0, 400
    );
    sumNassoc = 0.0;
    countNassocEvents = 0;
    hMult_ch_cent.resize(nCentBins, nullptr);
    hSignal_chch_cent.resize(nCentBins, nullptr);
    hBackground_chch_cent.resize(nCentBins, nullptr);
    CentPtBins_all.resize(nCentBins);

    for (int iCentBin = 0; iCentBin < nCentBins; iCentBin++) {
        TFileDirectory centDir = fs->mkdir(Form("anaTracks_cent%d_%s", iCentBin, centBinLabel[iCentBin]));

        hMult_ch_cent[iCentBin] = centDir.make<TH1D>(
            Form("hMult_ch_cent%d", iCentBin),
            Form("charged multiplicity for ch-ch reference (%s%%);N_{ch};Events", centBinLabel[iCentBin]),
            400, 0, 400
        );
        hSignal_chch_cent[iCentBin] = centDir.make<TH2D>(
            Form("hSignal_chch_cent%d", iCentBin),
            Form("ch-ch same-event (%s%%);#Delta#eta;#Delta#phi", centBinLabel[iCentBin]),
            33, -4.95, 4.95, 31, -(0.5-1.0/32)*PI, (1.5-1.0/32)*PI
        );
        hBackground_chch_cent[iCentBin] = centDir.make<TH2D>(
            Form("hBackground_chch_cent%d", iCentBin),
            Form("ch-ch mixed-event (%s%%);#Delta#eta;#Delta#phi", centBinLabel[iCentBin]),
            33, -4.95, 4.95, 31, -(0.5-1.0/32)*PI, (1.5-1.0/32)*PI
        );
        hSignal_chch_cent[iCentBin]->Sumw2();
        hBackground_chch_cent[iCentBin]->Sumw2();

        CentPtBins_all[iCentBin].resize(nPtBins);
        for(int iPtBin = 0; iPtBin < nPtBins; iPtBin++){
            CentPtBins_all[iCentBin][iPtBin] = Histograms{};

            TFileDirectory ptDir = centDir.mkdir(Form("ptBin%d", iPtBin));
            Histograms& ptBin = CentPtBins_all[iCentBin][iPtBin];

            TString massName = Form("hmass_ptBin%d_cent%d", iPtBin, iCentBin);
            TString massTitle = Form("J/#psi mass spectrum (%s%%), %.1f < p_{T} < %.1f GeV/c", centBinLabel[iCentBin], ptCuts[iPtBin], ptCuts[iPtBin+1]);
            ptBin.hmass = ptDir.make<TH1D>(massName, massTitle, 60, 2.6, 3.5);
            ptBin.heta_ptBin = ptDir.make<TH1D>(
                Form("heta_ptBin%d_cent%d", iPtBin, iCentBin),
                Form("J/#psi #eta (%s%%), %.1f < p_{T} < %.1f GeV/c", centBinLabel[iCentBin], ptCuts[iPtBin], ptCuts[iPtBin+1]),
                120, -6, 6
            );
            ptBin.hphi_ptBin = ptDir.make<TH1D>(
                Form("hphi_ptBin%d_cent%d", iPtBin, iCentBin),
                Form("J/#psi #phi (%s%%), %.1f < p_{T} < %.1f GeV/c", centBinLabel[iCentBin], ptCuts[iPtBin], ptCuts[iPtBin+1]),
                90, -PI, PI
            );

            ptBin.PtMassBins_SB.resize(nMassBins);
            TFileDirectory massDir = ptDir.mkdir(Form("massBins_pt%d", iPtBin));

            for (int iMassBin = 0; iMassBin < nMassBins; iMassBin++) {
                ptBin.PtMassBins_SB[iMassBin] = MassBinHistograms{};
                MassBinHistograms& massBin = ptBin.PtMassBins_SB[iMassBin];
                TFileDirectory binDir = massDir.mkdir(Form("massBin%d", iMassBin));

                TString multName = Form("hMult_pt%d_mass%d_cent%d", iPtBin, iMassBin, iCentBin);
                TString multTitle = Form("Multiplicity, centBin%d, ptBin%d, massBin%d", iCentBin, iPtBin, iMassBin);
                massBin.hMult_bins = binDir.make<TH1D>(multName, multTitle, 100, 0, 100);

                TString sigName = Form("hSignal_pt%d_mass%d_cent%d", iPtBin, iMassBin, iCentBin);
                massBin.hSignal = binDir.make<TH2D>(sigName, ";#Delta#eta;#Delta#phi",
                                                    33,-4.95,4.95,31,-(0.5-1.0/32)*PI,(1.5-1.0/32)*PI);

                TString bkgName = Form("hBackground_pt%d_mass%d_cent%d", iPtBin, iMassBin, iCentBin);
                massBin.hBackground = binDir.make<TH2D>(bkgName, ";#Delta#eta;#Delta#phi",
                                                        33,-4.95,4.95,31,-(0.5-1.0/32)*PI,(1.5-1.0/32)*PI);

                massBin.hSignal->Sumw2();
                massBin.hBackground->Sumw2();
            }
        }
    }


    pVectVectVect_trg = new vector< vector< vector< vector<Particle_trg> > > >;
    pVectVect_ass = new vector< vector<Particle_ass> >;
    zvtxVect = new vector<float>;
    nNtrkoffline = new vector<int>;
    ncent = new vector<int>;
    ncentBin = new vector<int>;
}

// ------------ method called once each job just after ending the event loop  ------------
void OOJPsiSkim::endJob() {
  // Get total event counts
    int nevttotal_trg = (int)pVectVectVect_trg->size();
    int nevttotal_ass = (int)pVectVect_ass->size();

    for (int iCentBin = 0; iCentBin < nCentBins; iCentBin++) {
        // J/psi-h mixed-event background per centrality
        for (int iPtBin = 0; iPtBin < nPtBins; iPtBin++){
            for (int iMassBin = 0; iMassBin < nMassBins; iMassBin++) {
                Histograms& ptBin = CentPtBins_all[iCentBin][iPtBin];
                MassBinHistograms& h = ptBin.PtMassBins_SB[iMassBin];
                for(int nround=0; nround<20; nround++) {
                    int ncount = 0;
                    for(int nevt_trg = 0; nevt_trg < nevttotal_trg; nevt_trg++) {
                        if ((*ncentBin)[nevt_trg] != iCentBin) continue;
                        int nevt_ass = gRandom->Integer(nevttotal_ass);
                        if ((*ncentBin)[nevt_ass] != iCentBin) { nevt_trg--; continue; }
                        if(nevt_trg == nevt_ass) { nevt_trg--; continue; }
                        if(fabs((*zvtxVect)[nevt_trg]-(*zvtxVect)[nevt_ass])>0.5 ||
                           fabs((*nNtrkoffline)[nevt_trg] - (*nNtrkoffline)[nevt_ass]) > 10 ){
                            nevt_trg--;
                            ncount++;
                            if(ncount>5000) {nevt_trg++; ncount = 0;}
                            continue;
                        }

                        const auto& pVectTmp_trg = (*pVectVectVect_trg)[nevt_trg][iPtBin][iMassBin];
                        const auto& pVectTmp_ass = (*pVectVect_ass)[nevt_ass];
                        int nMult_trg = pVectTmp_trg.size();
                        if(nMult_trg == 0) continue;

                        for(const auto& part_trg : pVectTmp_trg) {
                            float eta_trg = part_trg.eta;
                            float phi_trg = part_trg.phi;

                            for(const auto& part_ass : pVectTmp_ass) {
                                float pt_ass = part_ass.pt;
                                float eta_ass = part_ass.eta;
                                float phi_ass = part_ass.phi;

                                float eff_ass = effhisto->GetBinContent(effhisto->FindBin(eta_ass,pt_ass,(*ncent)[nevt_ass]));
                                float fake_ass = fakehisto->GetBinContent(fakehisto->FindBin(eta_ass,pt_ass,(*ncent)[nevt_ass]));
                                float sec_ass = sechisto->GetBinContent(sechisto->FindBin(eta_ass,pt_ass,(*ncent)[nevt_ass]));
                                float mul_ass = mulhisto->GetBinContent(mulhisto->FindBin(eta_ass,pt_ass,(*ncent)[nevt_ass]));

                                float effweight_ass = eff_ass * (1 + mul_ass) / (1 - fake_ass) / (1 - sec_ass);
                                float deltaEta=eta_ass-eta_trg;
                                float deltaPhi=phi_ass-phi_trg;

                                float deltaEta_mu1 = part_trg.eta_mu1 - eta_ass;
                                float deltaPhi_mu1 = part_trg.phi_mu1 - phi_ass;
                                float deltaEta_mu2 = part_trg.eta_mu2 - eta_ass;
                                float deltaPhi_mu2 = part_trg.phi_mu2 - phi_ass;

                                if(deltaPhi>PI) deltaPhi=deltaPhi-2*PI;
                                if(deltaPhi<-PI) deltaPhi=deltaPhi+2*PI;
                                if(deltaPhi>-PI && deltaPhi<-PI/2.) deltaPhi=deltaPhi+2*PI;

                                if(deltaPhi_mu1 > PI) deltaPhi_mu1 -= 2*PI;
                                if(deltaPhi_mu1 < -PI) deltaPhi_mu1 += 2*PI;
                                if(deltaPhi_mu1 > -PI && deltaPhi_mu1 < -PI/2.) deltaPhi_mu1 += 2*PI;

                                if(deltaPhi_mu2 > PI) deltaPhi_mu2 -= 2*PI;
                                if(deltaPhi_mu2 < -PI) deltaPhi_mu2 += 2*PI;
                                if(deltaPhi_mu2 > -PI && deltaPhi_mu2 < -PI/2.) deltaPhi_mu2 += 2*PI;

                                if(fabs(deltaEta)==0 && fabs(deltaPhi)==0) continue;
                                if((fabs(deltaEta_mu1)<tolerance && fabs(deltaPhi_mu1)<tolerance) ||
                                   (fabs(deltaEta_mu2)<tolerance && fabs(deltaPhi_mu2)<tolerance)) continue;
                                h.hBackground->Fill(deltaEta, deltaPhi, 1.0/nMult_trg/effweight_ass);
                            }
                        }
                    }
                }
            }
        }

        // ch-ch mixed-event reference per centrality
        for (int nround = 0; nround < 20; nround++) {
            int ncount = 0;
            for (int nevt_trg = 0; nevt_trg < nevttotal_trg; nevt_trg++) {
                if ((*ncentBin)[nevt_trg] != iCentBin) continue;
                int nevt_ass = gRandom->Integer(nevttotal_ass);
                if ((*ncentBin)[nevt_ass] != iCentBin) { nevt_trg--; continue; }
                if (nevt_trg == nevt_ass) { nevt_trg--; continue; }
                if (fabs((*zvtxVect)[nevt_trg] - (*zvtxVect)[nevt_ass]) > 0.5 ||
                    fabs((*nNtrkoffline)[nevt_trg] - (*nNtrkoffline)[nevt_ass]) > 10) {
                    nevt_trg--;
                    ncount++;
                    if (ncount > 5000) { nevt_trg++; ncount = 0; }
                    continue;
                }

                const auto& ch_trg = (*pVectVect_ass)[nevt_trg];
                const auto& ch_ass = (*pVectVect_ass)[nevt_ass];
                int nCh_trg = (int)ch_trg.size();
                if (nCh_trg == 0) continue;

                for (const auto& part_trg_ch : ch_trg) {
                    float eta_trg = part_trg_ch.eta;
                    float phi_trg = part_trg_ch.phi;
                    float pt_trg  = part_trg_ch.pt;

                    float eff_trg  = effhisto->GetBinContent(effhisto->FindBin(eta_trg, pt_trg, (*ncent)[nevt_trg]));
                    float fake_trg = fakehisto->GetBinContent(fakehisto->FindBin(eta_trg, pt_trg, (*ncent)[nevt_trg]));
                    float sec_trg  = sechisto->GetBinContent(sechisto->FindBin(eta_trg, pt_trg, (*ncent)[nevt_trg]));
                    float mul_trg  = mulhisto->GetBinContent(mulhisto->FindBin(eta_trg, pt_trg, (*ncent)[nevt_trg]));

                    float effweight_trg = eff_trg * (1 + mul_trg) / (1 - fake_trg) / (1 - sec_trg);
                    if (effweight_trg <= 0) continue;

                    for (const auto& part_ass_ch : ch_ass) {
                        float deltaEta = part_ass_ch.eta - eta_trg;
                        float deltaPhi = part_ass_ch.phi - phi_trg;

                        if (deltaPhi > PI) deltaPhi -= 2 * PI;
                        if (deltaPhi < -PI) deltaPhi += 2 * PI;
                        if (deltaPhi > -PI && deltaPhi < -PI/2.) deltaPhi += 2 * PI;

                        if (fabs(deltaEta) < tolerance && fabs(deltaPhi) < tolerance) continue;
                        hBackground_chch_cent[iCentBin]->Fill(deltaEta, deltaPhi, 1.0 / nCh_trg / effweight_trg);
                    }
                }
            }
        }
    }
    std::cout << "\n========== N_assoc Summary ==========\n";
    if (countNassocEvents > 0) {
        double avgNassoc = sumNassoc / (double)countNassocEvents;
        std::cout << "Total events with J/psi: " << countNassocEvents << "\n";
        std::cout << "Average N_assoc per event: " << avgNassoc << "\n";
        std::cout << "Total associated particles: " << (long long)sumNassoc << "\n";
    }
    std::cout << "===================================\n";
}

